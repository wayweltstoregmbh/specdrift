{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://specdrift.dev/schemas/cli_output.schema.json",
  "title": "SpecDrift CLI output envelope",
  "type": "object",
  "required": ["tool", "status"],
  "properties": {
    "tool": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the command that produced this output."
    },
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "fail"],
      "description": "Overall result of the command."
    }
  }
}
