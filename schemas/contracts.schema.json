{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://specdrift.dev/schemas/contracts.schema.json",
  "title": "SpecDrift confirmed requirement contracts",
  "type": "object",
  "required": ["schema_version", "tool", "confirmed_at", "claim_store", "sources", "confirmation", "contracts"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "string", "enum": ["1.0"] },
    "tool": { "type": "string", "enum": ["specdrift confirm"] },
    "confirmed_at": { "type": "string", "minLength": 20 },
    "claim_store": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["file", "hash", "line_count"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "line_count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "confirmation": {
      "type": "object",
      "required": ["mode", "confirmation_text"],
      "properties": {
        "mode": { "type": "string", "enum": ["accept_current"] },
        "confirmation_text": { "type": "string", "minLength": 10 }
      }
    },
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "contract_id",
          "claim_id",
          "source_file",
          "source_hash",
          "source_line_start",
          "source_line_end",
          "statement",
          "contract_type",
          "priority",
          "required_mechanism",
          "forbidden_substitutions",
          "required_evidence",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "contract_id": { "type": "string", "pattern": "^contract_claim_\\d{3,}$" },
          "claim_id": { "type": "string", "pattern": "^claim_\\d{3,}$" },
          "source_file": { "type": "string", "minLength": 1 },
          "source_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "source_line_start": { "type": "integer", "minimum": 1 },
          "source_line_end": { "type": "integer", "minimum": 1 },
          "statement": { "type": "string", "minLength": 4 },
          "contract_type": {
            "type": "string",
            "enum": ["security", "technical", "constraint", "privacy", "ux", "acceptance", "functional", "context"]
          },
          "priority": { "type": "string", "enum": ["must", "must_not", "should", "acceptance", "context"] },
          "required_mechanism": {
            "type": "string",
            "enum": ["preserve_named_mechanism", "preserve_requirement"]
          },
          "forbidden_substitutions": { "type": "array", "items": { "type": "string" } },
          "required_evidence": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string", "enum": ["confirmed"] }
        }
      }
    }
  }
}
